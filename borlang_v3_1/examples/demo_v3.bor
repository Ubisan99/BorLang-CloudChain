# ─── 5. Vector Store ───
print("[5] Vector Store + Semantic Search")
store = vector_create(128)
vector_add(store, "python machine learning sklearn")
vector_add(store, "the weather is sunny today")
vector_add(store, "deep learning with pytorch and numpy")
vector_add(store, "italian pizza is delicious")
hits = vector_search(store, "python ML numpy", 2)
for h in hits
    print("  score=" + str(round(h["score"], 3)) + "  " + h["text"])
end
print("")

# ─── 6. Memory Sandbox (SQLite) ───
print("[6] Memory Sandbox")
