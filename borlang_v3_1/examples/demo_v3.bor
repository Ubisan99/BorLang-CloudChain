# ─── 8. SVD Compression ───
print("[8] SVD Lossy Compression")
mat = [[1,2,3,4], [2,4,6,8], [3,6,9,12]]
svd = svd_compress(mat, 1)
print("  rank-1 error = " + str(svd["frobenius_error"]))
print("  ratio        = " + str(svd["ratio"]))
print("")

# ─── 9. Honest Compression ───
print("[9] Compression: dict-coding vs zlib")
text = "the quick brown fox jumps over the lazy dog the quick brown fox is fast the quick fox runs"
zh = compress_zh(text)
print("  char_reduction  = " + str(round(zh["char_reduction"], 3)))
print("  byte_reduction  = " + str(round(zh["byte_reduction_utf8"], 3)) + " (may be negative!)")
zl = compress_zlib(text)
print("  zlib reduction  = " + str(round(zl["byte_reduction"], 3)))
print("")

