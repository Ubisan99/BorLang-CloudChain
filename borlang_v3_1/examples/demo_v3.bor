# ─── 15. User Functions + Closures ───
print("[15] Functions & Closures")
def fibonacci(n)
    if n <= 1
        return n
    end
    a = 0
    b = 1
    i = 2
    while i <= n
        tmp = a + b
        a = b
        b = tmp
        i = i + 1
    end
    return b
end

print("  fib(10) = " + str(fibonacci(10)))
print("  fib(20) = " + str(fibonacci(20)))

def make_counter(start)
    count = start
    def tick()
        count = count + 1
        return count
    end
    return tick
end

c = make_counter(0)
print("  counter: " + str(c()) + ", " + str(c()) + ", " + str(c()))

# ─── 16. Control Flow ───
print("")
print("[16] Control Flow")
x = 42
if x > 100
    print("  big")
elif x > 10
    print("  medium: " + str(x))
else
    print("  small")
end

total = 0
for n in range(1, 11)
    total = total + n
end
print("  sum(1..10) = " + str(total))

