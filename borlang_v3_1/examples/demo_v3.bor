memory_save(mem, "user", {name: "Borty", brand: "BortyDrip", city: "Milan"})
memory_save(mem, "session", {theme: "cyberpunk", accent: "amber"})
user = memory_recall(mem, "user")
print("  user.name  = " + user["name"])
print("  user.brand = " + user["brand"])
print("  stats      = " + str(memory_stats(mem)))
print("")

